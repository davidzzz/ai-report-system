  },
  "devDependencies": {
    "@types/express": "^5.0.3",
    "@types/node": "^24.6.0",
    "@types/pdfkit": "^0.17.3",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.9.3"
  }
